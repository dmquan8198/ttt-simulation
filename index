<script>
// ══════════════════════════════════════════════
// ENGINE
// ══════════════════════════════════════════════
const LS=.04,PX=5e6,UN=['A','B','C'],MC=1e-6;
const UCOL=['#2563eb','#d97706','#059669'];
const UBGL=['rgba(37,99,235,.08)','rgba(217,119,6,.08)','rgba(5,150,105,.08)'];
let S,aU=0,lsgd=[],loPri=[];
function mkU(){return{vi:1e8,cd:0,cash:0,int:0,sN:0,sR:0,laiLog:[],capDiff:0,n31:0,lots:[]};}
function eL(u,i){if(!u.lots[i])u.lots[i]={qty:0,capDiff:0};}
function mkC(f,r,t,q){return{face:f,rate:r,tenor:t,qty:q,p0:0,pN:0,pX:0,s:0,e:t};}
let cL=[mkC(1e10,6,365,1),mkC(1e5,7,365,1e4),mkC(1e6,7.24,730,123),mkC(1e7,6.54,365,1232)];
function pR(p){return Math.round(p*100)/100;}
function cT0(f,r,t){return pR(f*(1+r/100*t/365)/Math.pow(1+LS/365,t));}
function iCL(){cL.forEach(l=>{l.p0=cT0(l.face,l.rate,l.tenor);l.pN=l.p0;l.pX=pR(l.p0+l.p0*LS/365);l.e=l.s+l.tenor;});}
function gAP(){const b=cL.filter(l=>l.qty>0).sort((a,b)=>b.qty-a.qty)[0];return b?(b.pN||b.p0):0;}
function fN(n){return n==null?'0đ':Math.round(n).toLocaleString('vi-VN')+'đ';}
function fCD(n){return n.toFixed(6);}
function fP(n){return n.toLocaleString('vi-VN',{minimumFractionDigits:2,maximumFractionDigits:2})+'đ';}
function gA(id){return parseInt((document.getElementById(id).value||'').replace(/\D/g,''))||0;}
const _p={};function sV(id,v){const e=document.getElementById(id);if(!e)return;const p=_p[id];e.textContent=v;if(p!==undefined&&p!==v){e.classList.remove('chg');void e.offsetWidth;e.classList.add('chg');}_p[id]=v;}
function clearHL(){document.querySelectorAll('.chg').forEach(e=>e.classList.remove('chg'));}
function log(m,t=''){const e=document.getElementById('lb');const c=t==='err'?'var(--neg)':t==='ok'?'var(--pos)':t==='warn'?'var(--warn)':'var(--muted)';e.innerHTML=`<b style="color:${c}">[${t||'info'}]</b> ${m}`;}

// Action Log
let aLog=[];
function snapState(){
  return{
    day:S.day,bId:S.bId,phase:S.phase,price:S.price,
    thuHo:S.thuHo,pool:S.pool,sN:S.sN,sU:S.sU,
    vT:S.vT,vMT:S.vMT,vFCD:+S.vFCD.toFixed(6),
    users:S.users.map((u,i)=>({
      n31:u.n31,cd:+u.cd.toFixed(6),cash:u.cash,vi:u.vi,
      capDiff:+u.capDiff.toFixed(6),int:u.int,sN:u.sN,sR:u.sR,
      lots:u.lots.map(l=>l?{qty:+l.qty.toFixed(6),cap:+(l.capDiff||0).toFixed(6)}:null).filter(Boolean),
      vUCD:+S.vUCD[i].toFixed(6),vUC:S.vUC[i]
    }))
  };
}
function aLogAdd(action,params){
  const state=snapState();
  aLog.push({step:aLog.length+1,action,params:params||{},state});
}
function copyLog(){
  const lines=aLog.map(e=>{
    const p=Object.entries(e.params).map(([k,v])=>k+'='+v).join(', ');
    const s=e.state;
    const uSum=s.users.map((u,i)=>'  '+UN[i]+': N31='+fN(u.n31)+' CD='+u.cd+' Cash='+u.cash+' capDiff='+u.capDiff+(u.lots.length?' lots=['+u.lots.map(l=>l.qty).join(',')+']':'')).join('\n');
    return`[Step ${e.step}] ${e.action}${p?' ('+p+')':''}\n  Day=T${s.day} Phiên=${s.bId} Phase=${s.phase} Giá=${fP(s.price)}\n  ThuHo=${fN(s.thuHo)} Pool=${fN(s.pool)} sN=${fN(s.sN)} sU=${fN(s.sU)}\n  VCB: vT=${fN(s.vT)} vMT=${fN(s.vMT)} vFCD=${s.vFCD}\n${uSum}`;
  }).join('\n─────────────────────────────────\n');
  const txt='TTT-New Simulation Log ('+aLog.length+' steps)\n═══════════════════════════════════\n'+lines;
  // Show in modal textarea for manual copy
  let m=document.getElementById('logModal');
  if(!m){
    m=document.createElement('div');m.id='logModal';
    m.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
    m.innerHTML='<div style="background:#fff;border-radius:6px;padding:12px;width:100%;max-width:700px;max-height:80vh;display:flex;flex-direction:column;gap:8px"><div style="display:flex;justify-content:space-between;align-items:center"><b style="font-size:12px">Action Log ('+aLog.length+' steps) — Ctrl+A rồi Ctrl+C để copy</b><button onclick="document.getElementById(\'logModal\').style.display=\'none\'" style="border:1px solid #ccc;background:#f5f5f5;padding:2px 8px;cursor:pointer;border-radius:3px;font-size:11px">✕ Đóng</button></div><textarea id="logTA" style="flex:1;min-height:300px;font-family:IBM Plex Mono,monospace;font-size:10px;padding:8px;border:1px solid #ddd;border-radius:3px;resize:none" readonly></textarea></div>';
    document.body.appendChild(m);
  }
  m.style.display='flex';
  m.querySelector('b').textContent='Action Log ('+aLog.length+' steps) — Ctrl+A rồi Ctrl+C để copy';
  const ta=document.getElementById('logTA');
  ta.value=txt;
  ta.focus();ta.select();
}

// ═══ Actions Export / Replay ═══
function actionsToText(){
  // Export only actionable steps (skip RESET at step 1)
  return aLog.filter(e=>e.action!=='RESET').map(e=>{
    const a=e.action,p=e.params;
    if(a==='NẠP') return 'NAP '+p.user+' '+p.amount;
    if(a==='RÚT') return 'RUT '+p.user+' '+p.amount;
    if(a==='JOB_RÚT') return 'JOB_RUT';
    if(a==='JOB_MOMO') return 'JOB_MOMO';
    if(a==='JOB_NẠP') return 'JOB_NAP';
    if(a==='ĐÓNG_PHIÊN') return 'DONG_PHIEN';
    if(a==='QUA_NGÀY') return 'QUA_NGAY';
    if(a==='NHẬP_KHO') return 'NHAP_KHO '+p.face+' '+p.rate+' '+p.tenor+' '+p.qty;
    if(a==='SET_PRIORITY') return 'SET_PRI '+p.loPri;
    if(a==='RESET_PRIORITY') return 'RESET_PRI';
    if(a==='ROLLBACK') return 'ROLLBACK';
    return '# '+a+' '+JSON.stringify(p);
  }).join('\n');
}

function copyActions(){
  const txt=actionsToText();
  if(!txt){log('Chưa có actions','err');return;}
  showModal('Copy Actions — Ctrl+A → Ctrl+C',txt,true);
}

function showReplay(){
  showModal('Paste Actions rồi bấm ▶ Replay','',false);
}

function showModal(title,content,readonly){
  let m=document.getElementById('actModal');
  if(!m){
    m=document.createElement('div');m.id='actModal';
    m.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
    m.innerHTML=`<div style="background:#fff;border-radius:6px;padding:12px;width:100%;max-width:600px;max-height:80vh;display:flex;flex-direction:column;gap:8px">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <b id="actTitle" style="font-size:12px"></b>
        <button onclick="document.getElementById('actModal').style.display='none'" style="border:1px solid #ccc;background:#f5f5f5;padding:2px 8px;cursor:pointer;border-radius:3px;font-size:11px">✕</button>
      </div>
      <textarea id="actTA" style="flex:1;min-height:250px;font-family:IBM Plex Mono,monospace;font-size:11px;padding:8px;border:1px solid #ddd;border-radius:3px;resize:none"></textarea>
      <div style="display:flex;gap:6px;justify-content:flex-end">
        <button id="actReplayBtn" onclick="runReplay()" style="padding:4px 14px;border:1.5px solid #b45309;background:rgba(180,83,9,.08);color:#b45309;font-weight:600;font-size:11px;cursor:pointer;border-radius:3px">▶ Replay</button>
      </div>
      <div id="actStatus" style="font-family:IBM Plex Mono,monospace;font-size:10px;color:#888;max-height:80px;overflow-y:auto"></div>
    </div>`;
    document.body.appendChild(m);
  }
  m.style.display='flex';
  document.getElementById('actTitle').textContent=title;
  const ta=document.getElementById('actTA');
  ta.value=content;
  ta.readOnly=!!readonly;
  document.getElementById('actReplayBtn').style.display=readonly?'none':'block';
  document.getElementById('actStatus').textContent='';
  ta.focus();
  if(readonly)ta.select();
}

function runReplay(){
  const txt=document.getElementById('actTA').value.trim();
  if(!txt){log('Không có actions','err');return;}
  const lines=txt.split('\n').map(l=>l.trim()).filter(l=>l&&!l.startsWith('#'));
  const status=document.getElementById('actStatus');
  
  resetAll();
  let ok=0,fail=0;
  const userMap={A:0,B:1,C:2};
  
  for(const line of lines){
    const parts=line.split(/\s+/);
    const cmd=parts[0];
    try{
      if(cmd==='NAP'){
        const ui=userMap[parts[1]];const amt=parseInt(parts[2]);
        aU=ui;document.getElementById('inap').value=String(amt);doNap();ok++;
      }else if(cmd==='RUT'){
        const ui=userMap[parts[1]];const amt=parseInt(parts[2]);
        aU=ui;document.getElementById('irut').value=String(amt);doRut();ok++;
      }else if(cmd==='JOB_RUT'){jRut();ok++;}
      else if(cmd==='JOB_MOMO'){jMoMo();ok++;}
      else if(cmd==='JOB_NAP'){jNap();ok++;}
      else if(cmd==='DONG_PHIEN'){closeSes();ok++;}
      else if(cmd==='QUA_NGAY'){advDay();ok++;}
      else if(cmd==='NHAP_KHO'){
        const f=parseFloat(parts[1]),r=parseFloat(parts[2]),t=parseInt(parts[3]),q=parseFloat(parts[4]);
        importCDx(f,r,t,q);ok++;
      }else if(cmd==='SET_PRI'){
        loPri=JSON.parse(parts.slice(1).join(' '));
        aLogAdd('SET_PRIORITY',{loPri:JSON.stringify(loPri)});renderCDLo();ok++;
      }else if(cmd==='RESET_PRI'){
        loPri=[];aLogAdd('RESET_PRIORITY',{});renderCDLo();ok++;
      }else if(cmd==='ROLLBACK'){rollback();ok++;}
      else{fail++;status.textContent+='⚠ Unknown: '+line+'\n';}
    }catch(e){fail++;status.textContent+='✗ Error: '+line+' → '+e.message+'\n';}
  }
  status.textContent='✓ Replay hoàn tất: '+ok+' actions OK'+(fail?' | '+fail+' failed':'')+'\n'+status.textContent;
  log('Replay: '+ok+' actions'+(fail?', '+fail+' failed':''),'ok');
  document.getElementById('actModal').style.display='none';
}
function uTab(n){document.querySelectorAll('#utp0,#utp1').forEach((e,i)=>e.className='tpane'+(i===n?' on':''));document.querySelectorAll('.pnl:first-child .tab').forEach((e,i)=>e.className='tab'+(i===n?' on':''));}
function tTab(n){for(let i=0;i<4;i++){const e=document.getElementById('ttp'+i);if(e)e.className='tpane'+(i===n?' on':'');}document.querySelectorAll('.pnl:nth-child(3) .tab').forEach((e,i)=>e.className='tab'+(i===n?' on':''));if(n===3)renderPriceTable();}
function vTab(n){document.querySelectorAll('#vtp0,#vtp1').forEach((e,i)=>e.className='tpane'+(i===n?' on':''));document.querySelectorAll('.pnl:last-child .tab').forEach((e,i)=>e.className='tab'+(i===n?' on':''));}

// Snapshot for rollback
let snap=null,snapName='';
function saveSnap(name){snap=JSON.parse(JSON.stringify({users:S.users,thuHo:S.thuHo,pool:S.pool,sN:S.sN,sU:S.sU,sW:S.sW,vUCD:S.vUCD,vUC:S.vUC,vFCD:S.vFCD,vFC:S.vFC,vT:S.vT,vMT:S.vMT,jobs:S.jobs,phase:S.phase,cdList:cL.map(l=>({...l}))}));snapName=name;document.getElementById('brl').disabled=false;document.getElementById('rlbl').textContent='Hoàn tác: '+name;}
function rollback(){if(!snap){log('Không có snapshot','err');return;}Object.assign(S,{users:snap.users,thuHo:snap.thuHo,pool:snap.pool,sN:snap.sN,sU:snap.sU,sW:snap.sW,vUCD:snap.vUCD,vUC:snap.vUC,vFCD:snap.vFCD,vFC:snap.vFC,vT:snap.vT,vMT:snap.vMT,jobs:snap.jobs,phase:snap.phase});snap.cdList.forEach((l,i)=>{if(cL[i])Object.assign(cL[i],l);});snap=null;document.getElementById('brl').disabled=true;document.getElementById('rlbl').textContent='Hoàn tác job vừa chạy';log('Rollback ✓ → trước "'+snapName+'"','warn');aLogAdd('ROLLBACK',{target:snapName});render();}

// LSGD
function addLsgd(uIdx,type,qty,price,paid,loIdx){lsgd.unshift({b:String(S.bId).padStart(4,'0'),u:uIdx,type,qty,price,paid,lo:loIdx!=null?loIdx:-1});if(lsgd.length>80)lsgd.pop();renderLsgd();}
function renderLsgd(){const tb=document.getElementById('lsgdB');if(!tb)return;const labels='ABCDEFGH';if(!lsgd.length){tb.innerHTML='<tr><td colspan="7" style="color:var(--muted)">Chưa có</td></tr>';return;}tb.innerHTML=lsgd.slice(0,40).map(r=>{const n=UN[r.u];const tl=r.type==='buy'?'▲ Mua':r.type==='sell'?'▼ Bán':r.type==='deposit'?'▶ Nạp':'◀ Rút';const loTag=r.lo>=0?'Lô '+labels[r.lo]:'–';return`<tr><td>${r.b}</td><td style="color:${UCOL[r.u]};font-weight:600">${n}</td><td>${tl}</td><td>${loTag}</td><td>${r.qty>0?fCD(r.qty):'–'}</td><td>${r.price>0?fP(r.price):'–'}</td><td>${fN(r.paid)}</td></tr>`;}).join('');}

// CD lot management
function renderCDLo(){const el=document.getElementById('cdLoList');const labels='ABCDEFGH';el.innerHTML=cL.map((lo,i)=>{const inP=loPri.indexOf(i);const rank=inP>=0?inP+1:null;return`<div class="lo-card"><div class="lo-h">Lô ${labels[i]}${rank?' <span style="color:var(--pos)">#'+rank+'</span>':''} <button onclick="togPri(${i})" style="float:right;font-size:7px;padding:1px 4px;border:1px solid var(--tvam);border-radius:2px;background:${rank?'rgba(180,83,9,.12)':'var(--surface2)'};color:var(--tvam);cursor:pointer">${rank?'Bỏ':'Chọn'}</button></div><div class="ur"><span>MG ${fN(lo.face)}</span><span>LS ${lo.rate}%</span><span>${lo.tenor}ng</span></div><div class="ur"><span>Qty: ${fCD(lo.qty)}</span><span>Giá: ${fP(lo.pN||lo.p0)}</span></div></div>`;}).join('');document.getElementById('loPriDisp').textContent=loPri.length?'Thứ tự: '+loPri.map(i=>'Lô '+labels[i]).join(' → '):'Auto (qty giảm dần)';}
function renderVCDLo(){const el=document.getElementById('vcdLo');const labels='ABCDEFGH';el.innerHTML=cL.map((lo,i)=>{const val=Math.round(lo.qty*(lo.pN||lo.p0));return`<div class="lo-card"><div class="lo-h">Lô ${labels[i]}</div><div class="ur"><span>Qty: ${fCD(lo.qty)}</span><span>Giá trị: ${fN(val)}</span></div></div>`;}).join('');}
function togPri(i){const idx=loPri.indexOf(i);if(idx>=0)loPri.splice(idx,1);else loPri.push(i);aLogAdd('SET_PRIORITY',{loPri:JSON.stringify(loPri)});renderCDLo();}
function resetPri(){loPri=[];aLogAdd('RESET_PRIORITY',{});renderCDLo();}
function importCD(){const f=parseFloat(document.getElementById('ci-f').value)||0,r=parseFloat(document.getElementById('ci-r').value)||0,t=parseInt(document.getElementById('ci-t').value)||0,q=parseFloat(document.getElementById('ci-q').value)||0;importCDx(f,r,t,q);}
function importCDx(f,r,t,q){if(!f||!r||!t||!q){log('Thông tin lô CD không hợp lệ','err');return;}const p0=cT0(f,r,t);const nl={face:f,rate:r,tenor:t,qty:q,p0,pN:p0,pX:pR(p0+p0*LS/365),s:S.day,e:S.day+t};cL.push(nl);S.vFCD=Math.round((S.vFCD+q)*1e6)/1e6;renderCDLo();renderVCDLo();aLogAdd('NHẬP_KHO',{face:f,rate:r,tenor:t,qty:q});log('Nhập kho: '+q+' CD | MG '+fP(f)+' | LS '+r+'% | '+t+'ngày','ok');render();}

// Lai log
function renderLaiLog(){const el=document.getElementById('laiLog');el.innerHTML=S.users.map((u,i)=>{if(!u.laiLog.length)return`<div style="margin-bottom:4px"><div style="font-size:8px;font-weight:600;color:${UCOL[i]}">User ${UN[i]}</div><div style="font-size:8px;color:var(--muted)">Chưa có lãi</div></div>`;return`<div style="margin-bottom:4px"><div style="font-size:8px;font-weight:600;color:${UCOL[i]}">User ${UN[i]}</div>${[...u.laiLog].reverse().map(l=>`<div class="lai-row"><span style="color:var(--muted)">T${l.day}</span><span style="color:var(--pos);font-weight:600">+${fN(l.lai)}</span></div>`).join('')}</div>`;}).join('');}

// Price table
let ptLo=0;
function renderPtLoSel(){const el=document.getElementById('ptLoSel');if(!el)return;const labels='ABCDEFGH';el.innerHTML=cL.map((lo,i)=>`<button onclick="selPtLo(${i})" style="font-size:8px;padding:2px 6px;border:1.5px solid ${i===ptLo?'var(--tvam)':'var(--border2)'};border-radius:2px;background:${i===ptLo?'rgba(180,83,9,.12)':'var(--surface2)'};color:${i===ptLo?'var(--tvam)':'var(--muted)'};cursor:pointer;font-weight:600">Lô ${labels[i]}</button>`).join('');}
function selPtLo(i){ptLo=i;renderPtLoSel();renderPriceTable();}
function renderPriceTable(){
  renderPtLoSel();
  const tb=document.getElementById('ptBody');if(!tb||!cL[ptLo])return;
  const lo=cL[ptLo];
  const prices=[lo.p0];
  for(let d=1;d<=lo.tenor;d++) prices.push(pR(prices[d-1]+prices[d-1]*LS/365));
  let rows='';
  for(let d=0;d<=lo.tenor;d++){
    const p=prices[d];const prev=d>0?prices[d-1]:lo.p0;
    const lai=d>0?pR(p-prev):0;
    const isCur=d===S.day;const isMat=d===lo.tenor;
    const style=isMat?'font-weight:600;color:var(--pos);background:rgba(34,197,94,.07)':isCur?'background:rgba(217,119,6,.12);font-weight:600':'';
    const label=d===0?'T0':isMat?`T${d} ★`:`T${d}`;
    rows+=`<tr style="${style}"><td>${label}${isCur&&!isMat?' ◀':''}</td><td>${fP(p)}</td><td>${d>0?'+'+fP(lai):'–'}</td><td>${fN(Math.round(lo.qty*p))}</td></tr>`;
  }
  tb.innerHTML=rows;
}

function resetAll(){
  cL=[mkC(1e10,6,365,1),mkC(1e5,7,365,1e4),mkC(1e6,7.24,730,123),mkC(1e7,6.54,365,1232)];iCL();
  S={day:0,bId:1,price:gAP(),phase:'IDLE',users:[mkU(),mkU(),mkU()],thuHo:0,pool:PX,sN:0,sU:0,sW:0,vUCD:[0,0,0],vUC:[0,0,0],vFCD:cL.reduce((s,l)=>s+l.qty,0),vFC:0,vT:0,vMT:0,jobs:{r:0,m:0,n:0}};
  aU=0;lsgd=[];loPri=[];snap=null;fSt=[];fI=-1;fPl=false;clearInterval(fTm);clearHL();aLog=[];aLogAdd('RESET',{});
  document.getElementById('brl').disabled=true;document.getElementById('rlbl').textContent='Hoàn tác job vừa chạy';
  bldH();clrB();uFB();renderCDLo();renderVCDLo();renderLsgd();renderLaiLog();renderPriceTable();
  const ah=document.getElementById('advHint');if(ah)ah.style.display='none';
  log('Reset.');render();
}

