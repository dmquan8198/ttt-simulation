function jRut(){
  saveSnap('Job Rút');S.phase='JOBS';let tS=0,tC=0,aW=0;const perU=[];
  S.users.forEach((u,i)=>{
    const net=u.sN-u.sR; // net phiên: dương=nạp nhiều hơn, âm=rút nhiều hơn
    if(net>=0){perU.push(null);return;} // net >= 0 → không cần bán CD, thuộc Job Nạp
    const needSell=Math.abs(net); // cần bán CD đúng bằng |net|
    let uSell=0,uCash=0;
    // Sell CD
    u.cd=Math.round(u.lots.reduce((s,l)=>s+(l?l.qty:0),0)*1e6)/1e6;
    const rutHet=u.n31===0&&u.sR>0; // rút hết N31
    let tQ=0;const sp=[];
    if(rutHet&&u.cd>0){
      u.lots.forEach((l,li)=>{if(!l||l.qty<=0)return;const p=cL[li]?.pN||0;if(p<=0)return;sp.push({li,qty:l.qty,price:p,cd:l.capDiff||0});tQ=Math.round((tQ+l.qty)*1e6)/1e6;});
    }else{
      let rm=needSell-u.cash; // cần bán thêm bao nhiêu sau khi trừ cash hiện có
      if(rm>0){for(let li=0;li<u.lots.length;li++){const l=u.lots[li];if(!l||l.qty<=0||rm<=0)continue;const p=cL[li]?.pN||0;if(p<=0)continue;const qN=Math.ceil(rm/p*1e6)/1e6;const df=Math.round((l.qty-qN)*1e6)/1e6;const q=(df>=0&&df<MC)?l.qty:Math.min(qN,l.qty);const c=Math.floor(q*p);sp.push({li,qty:q,price:p,cd:l.capDiff||0});rm=Math.max(0,Math.round((rm-c)*100)/100);tQ=Math.round((tQ+q)*1e6)/1e6;}}
    }
    if(tQ>=MC){
      const co=sp.reduce((s,p)=>{const qC=Math.min(p.qty,p.cd);const pT=pR(p.price*(1+LS/365));return s+Math.floor(qC*pT+(p.qty-qC)*p.price);},0);
      let rS=tQ;u.lots.forEach((l,li)=>{if(!l||l.qty<=0||rS<=0)return;const sl=Math.min(rS,Math.round(l.qty*1e6)/1e6);l.qty=Math.round((l.qty-sl)*1e6)/1e6;const cF=Math.min(sl,l.capDiff||0);l.capDiff=Math.round(((l.capDiff||0)-cF)*1e6)/1e6;if(cL[li])cL[li].qty=Math.round((cL[li].qty+sl)*1e6)/1e6;rS=Math.round((rS-sl)*1e6)/1e6;});
      u.cd=Math.round(u.lots.reduce((s,l)=>s+(l?l.qty:0),0)*1e6)/1e6;u.capDiff=Math.round(u.lots.reduce((s,l)=>s+(l?l.capDiff:0),0)*1e6)/1e6;
      u.cash+=co;S.vUCD[i]=Math.round((S.vUCD[i]-tQ)*1e6)/1e6;S.vFCD=Math.round((S.vFCD+tQ)*1e6)/1e6;S.vUC[i]=Math.round((S.vUC[i]+co)*100)/100;S.vFC=Math.round((S.vFC+co)*100)/100;
      uSell=tQ;uCash=co;tS+=tQ;tC+=co;addLsgd(i,'sell',tQ,sp[0]?.price||0,co,sp[0]?.li);
    }
    // Withdraw: trừ cash
    // Nếu bán hết CD (cd=0) → trừ sạch cash (needSell + cash_remain)
    // Phần cash_remain thừa sẽ đọng lại ở Thu hộ TVAM
    const soldAll = u.cd < MC; // bán hết CD
    const wdAmt = soldAll ? Math.max(needSell, Math.round(u.cash)) : needSell;
    const cashExtra = soldAll ? Math.max(0, Math.round(u.cash) - needSell) : 0; // phần cash_remain thừa
    const w = Math.min(u.cash, wdAmt);
    u.cash = Math.round((u.cash - w) * 100) / 100;
    if(soldAll && u.cash > 0 && u.cash < 1) u.cash = 0; // clear dust
    S.vUC[i] = Math.round((S.vUC[i] - w) * 100) / 100;
    aW += wdAmt;
    perU.push({sell:uSell, cash:uCash, wd:needSell, cashExtra});
  });
  if(aW>0)S.thuHo=Math.round((S.thuHo+aW)*100)/100;S.sW=aW;S.jobs.r=1;
  log('Job Rút ✓','ok');aLogAdd('JOB_RÚT',{totalSell:fCD(tS),totalCash:tC,totalWd:aW});addF('jobRut',null,{tS,tC,aW,perU});render();renderCDLo();
}
function jMoMo(){
  saveSnap('Job MoMo');S.phase='JOBS';
  // Thu hộ TVAM chứa: tiền nạp (sN) + tiền withdraw hoàn (từ jRut)
  // Job MoMo chỉ xử lý:
  //   1. Refill Pool = sU (phần Pool đã ứng cho rút realtime)
  //   2. Chuyển net nạp phiên (sN) qua VCB → deposit_Tổng
  // Phần còn lại (cash_remain đọng) giữ nguyên tại Thu hộ TVAM
  const rf = Math.min(S.sU, S.thuHo); // refill Pool đúng bằng số đã ứng
  if(rf>0){S.pool=Math.round((S.pool+rf)*100)/100;S.thuHo=Math.round((S.thuHo-rf)*100)/100;}
  const netNap = S.sN; // phần net nạp phiên chuyển qua VCB
  const transfer = Math.min(netNap, S.thuHo); // không chuyển nhiều hơn thuHo còn lại
  if(transfer>0){
    S.thuHo=Math.round((S.thuHo-transfer)*100)/100;
    S.vMT=Math.round((S.vMT+transfer)*100)/100;
  }
  // deposit_Tổng: MoMo_Tổng → TVAM_Tổng
  const dp=Math.max(0,S.vMT);
  if(dp>0){S.vMT=Math.round((S.vMT-dp)*100)/100;S.vT=Math.round((S.vT+dp)*100)/100;}
  S.jobs.m=1;
  const dongLai=Math.round(S.thuHo); // phần đọng lại
  log('Job MoMo ✓ | Refill '+fN(rf)+' | Net nạp '+fN(transfer)+(dongLai>0?' | Đọng '+fN(dongLai):''),'ok');
  aLogAdd('JOB_MOMO',{refill:rf,transfer:transfer,deposit:dp,dongLai:dongLai});
  addF('jobMoMo',null,{rf,transfer,dp,dongLai});render();
}
