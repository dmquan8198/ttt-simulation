    });
    if(tS>0||aW>0)steps.push({phase:'Job Rút — VCB'});
    perU.forEach((pu,idx)=>{if(!pu||pu.sell<=0)return;const c=UCOL[idx],n=UN[idx];steps.push({from:'vtu',to:'vtf',label:n+' sell_CD',amt:fCD(pu.sell)+' CD',color:c,usr:idx});steps.push({from:'vtf',to:'vtu',label:n+' tiền bán',amt:fN(pu.cash),color:c,usr:idx});});
    if(aW>0){steps.push({from:'vtu',to:'vtt',label:'→ TVAM_Tổng',amt:fN(aW),color:'var(--vcb)'});steps.push({from:'vtt',to:'vmt',label:'→ MoMo_Tổng',amt:fN(aW),color:'var(--momo)'});steps.push({from:'vmt',to:'thv',label:'→ Thu hộ VCB',amt:fN(aW),color:'var(--momo)'});steps.push({from:'thv',to:'th',label:'→ Thu hộ TVAM (đọng '+fN(aW)+')',amt:fN(aW),color:'var(--momo)'});}
  }else if(action==='jobMoMo'){
    const{rf,transfer,dp,dongLai}=data;steps.push({phase:'Job MoMo'});
    if(rf>0)steps.push({from:'th',to:'pl',label:'Refill Pool (hoàn ứng)',amt:'+'+fN(rf),color:'var(--fs)'});
    if(transfer>0){
      steps.push({from:'th',to:'thv',label:'Net nạp → Thu hộ VCB',amt:fN(transfer),color:'var(--momo)'});
      steps.push({from:'thv',to:'vmt',label:'→ MoMo_Tổng',amt:fN(transfer),color:'var(--momo)'});
      if(dp>0)steps.push({from:'vmt',to:'vtt',label:'deposit_Tổng',amt:fN(dp),color:'var(--vcb)'});
    }
    if(dongLai>0)steps.push({from:'th',to:'th',label:'Đọng tại Thu hộ TVAM',amt:fN(dongLai),color:'var(--muted)',self:true});
  }else if(action==='jobNap'){
    const{aD,tB,tP,perU}=data;steps.push({phase:'Job Nạp — TVAM'});
    perU.forEach((pu,idx)=>{if(!pu)return;const c=UCOL[idx],n=UN[idx];if(pu.dep>0)steps.push({from:'n31',to:'usr',label:n+' netoff',amt:fN(pu.dep),color:c,usr:idx});if(pu.buy>0){steps.push({from:'usr',to:'fs',label:n+' buy_CD',amt:fN(pu.paid),color:c,usr:idx});steps.push({from:'fs',to:'usr',label:n+' nhận CD',amt:fCD(pu.buy)+' CD',color:c,usr:idx});}});
    if(aD>0||tB>0)steps.push({phase:'Job Nạp — VCB'});
    perU.forEach((pu,idx)=>{if(!pu||pu.dep<=0)return;const c=UCOL[idx],n=UN[idx];steps.push({from:'vtt',to:'vtu',label:n+' deposit_User',amt:fN(pu.dep),color:c,usr:idx});if(pu.buy>0){steps.push({from:'vtu',to:'vtf',label:n+' buy_CD',amt:fN(pu.paid),color:c,usr:idx});steps.push({from:'vtf',to:'vtu',label:n+' CD→User',amt:fCD(pu.buy)+' CD',color:c,usr:idx});}});
  }else if(action==='interest'){
    const{day,perLai}=data;if(perLai.some(l=>l>0)){steps.push({phase:'T'+day+' — Tính lãi'});perLai.forEach((lai,idx)=>{if(lai<=0)return;steps.push({from:'n31',to:'n31',label:UN[idx]+' lãi T'+day,amt:'+'+fN(lai),color:UCOL[idx],self:true,usr:idx});});}
  }
  fSt.push(...steps);animSeq(fSt.length-steps.length);
}

let aQ=null;
function animSeq(si){if(aQ)clearTimeout(aQ);let i=si;(function nx(){if(i>=fSt.length)return;if(fSt[i].phase){fI=i;renderRows();i++;aQ=setTimeout(nx,250);return;}fI=i;renderRows();i++;aQ=setTimeout(nx,850);}());}

function renderRows(){
  const b=document.getElementById('sb');b.querySelectorAll('.seq-row,.seq-phase').forEach(e=>e.remove());let y=0;
  fSt.forEach((s,i)=>{
    if(s.phase){const d=document.createElement('div');d.className='seq-phase';d.style.height='22px';d.innerHTML=`<div class="seq-phase-lbl">▸ ${s.phase}</div>`;b.appendChild(d);y+=22;return;}
    const row=document.createElement('div');row.className='seq-row'+(i<=fI?' vis':'');row.style.height=RH+'px';row.dataset.idx=i;const c=s.color;
    if(s.usr!=null){const badge=document.createElement('div');badge.className='ubadge';badge.textContent=UN[s.usr];badge.style.background=UBGL[s.usr];badge.style.color=UCOL[s.usr];badge.style.border='1px solid '+UCOL[s.usr];row.appendChild(badge);}
    if(s.self){const cp=cP(s.from);const bar=document.createElement('div');bar.style.cssText=`position:absolute;left:calc(${cp}% - 5px);top:calc(50% - 12px);width:10px;height:24px;border:2px solid ${c};background:${c}22;border-radius:2px;z-index:5`;if(i===fI)bar.style.animation='actPulse .5s ease-out';row.appendChild(bar);const lbl=document.createElement('div');lbl.className='seq-lbl';lbl.style.cssText=`left:calc(${cp}% + 12px);top:50%;transform:translateY(-50%);bottom:auto;margin-bottom:0;color:${c};font-weight:600`;lbl.innerHTML=`${s.label} <b>${s.amt}</b>`;row.appendChild(lbl);b.appendChild(row);y+=RH;return;}
    const fp=cP(s.from),tp=cP(s.to),lp=Math.min(fp,tp),rp=Math.max(fp,tp),wp=rp-lp,goR=tp>fp;
    const arr=document.createElement('div');arr.className='seq-arrow';arr.style.cssText=`left:${lp}%;width:${wp}%;top:50%;transform:translateY(-50%);background:${c};position:absolute`;const hd=document.createElement('div');hd.className='arr-hd '+(goR?'r':'l');hd.style.color=c;hd.style.cssText+=`;position:absolute;top:50%;transform:translateY(-50%)`;if(goR)hd.style.right='0';else hd.style.left='0';arr.appendChild(hd);row.appendChild(arr);
    const lbl=document.createElement('div');lbl.className='seq-lbl';lbl.style.left=((lp+rp)/2)+'%';lbl.style.transform='translateX(-50%)';lbl.style.color=c;lbl.innerHTML=`${s.label} <b>${s.amt}</b>`;row.appendChild(lbl);
    const ball=document.createElement('div');ball.className='seq-ball';ball.style.background=c;ball.style.color=c;ball.style.top='calc(50% - 6px)';ball.dataset.from=fp;ball.dataset.to=tp;
    if(i===fI){ball.className='seq-ball ready';ball.style.left=fp+'%';setTimeout(()=>{ball.className='seq-ball moving';ball.style.left=tp+'%';setTimeout(()=>{ball.className='seq-ball arrived';ball.style.left=tp+'%';},650);},30);}
    else if(i<fI){ball.className='seq-ball arrived';ball.style.left=tp+'%';}else{ball.style.left=fp+'%';}
    row.appendChild(ball);b.appendChild(row);y+=RH;
  });
  b.style.minHeight=(y+40)+'px';
  if(fI>=0&&fI<fSt.length&&!fSt[fI].phase){const s=fSt[fI];document.getElementById('si').innerHTML=`<b>${fI+1}/${fSt.length}</b> — ${s.label} ${s.amt}`;}
  uFB();scrollV();
}
function scrollV(){const w=document.getElementById('sw');let y=0;for(let i=0;i<=fI&&i<fSt.length;i++)y+=fSt[i].phase?22:RH;w.scrollTo({top:Math.max(0,y-80),behavior:'smooth'});}
function nxS(f,d){let i=f+d;while(i>=0&&i<fSt.length){if(!fSt[i].phase)return i;i+=d;}return d>0?fSt.length-1:0;}
function showAt(idx){if(aQ)clearTimeout(aQ);fI=idx;renderRows();}
function fPrv(){showAt(nxS(fI,-1));}function fNxt(){showAt(nxS(fI,1));}
function fPly(){if(fPl){fPl=false;clearInterval(fTm);if(aQ)clearTimeout(aQ);uFB();return;}if(fI>=fSt.length-1)fI=-1;fPl=true;uFB();fTm=setInterval(()=>{const ni=nxS(fI,1);if(ni>fI){fI=ni;renderRows();}else{fPl=false;clearInterval(fTm);uFB();}},900);}
function fRpl(){fPl=false;clearInterval(fTm);if(aQ)clearTimeout(aQ);fI=-1;renderRows();setTimeout(()=>fPly(),200);}
function uFB(){document.getElementById('bp').disabled=fI<=0||!fSt.length;document.getElementById('bn').disabled=fI>=fSt.length-1;document.getElementById('bpl').disabled=!fSt.length;document.getElementById('br').disabled=!fSt.length;document.getElementById('bpl').textContent=fPl?'⏸':'▶ Play';document.getElementById('bpl').classList.toggle('act',fPl);}
// Resizer drag
(function(){
  const rz=document.getElementById('resizer'),main=document.querySelector('.main'),sim=document.querySelector('.sim');
  let dragging=false,startY=0,startH=0;
  rz.addEventListener('mousedown',e=>{dragging=true;startY=e.clientY;startH=sim.offsetHeight;rz.classList.add('active');document.body.style.cursor='ns-resize';document.body.style.userSelect='none';e.preventDefault();});
  document.addEventListener('mousemove',e=>{if(!dragging)return;const dy=e.clientY-startY;const newH=Math.max(150,Math.min(main.offsetHeight-100,startH+dy));sim.style.height=newH+'px';});
  document.addEventListener('mouseup',()=>{if(!dragging)return;dragging=false;rz.classList.remove('active');document.body.style.cursor='';document.body.style.userSelect='';});
  // Touch support
  rz.addEventListener('touchstart',e=>{dragging=true;startY=e.touches[0].clientY;startH=sim.offsetHeight;rz.classList.add('active');e.preventDefault();},{passive:false});
  document.addEventListener('touchmove',e=>{if(!dragging)return;const dy=e.touches[0].clientY-startY;const newH=Math.max(150,Math.min(main.offsetHeight-100,startH+dy));sim.style.height=newH+'px';},{passive:false});
  document.addEventListener('touchend',()=>{if(!dragging)return;dragging=false;rz.classList.remove('active');});
  // Set initial height
  sim.style.height='42%';
})();
iCL();resetAll();
</script>
