<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>TTT-New — Flow Simulator v5</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#f5f4ef;--surface:#fff;--surface2:#eeeee6;--border:#dddbd2;--border2:#c8c6bc;--text:#1a1916;--muted:#888078;--dim:#bbb;--user:#2563eb;--momo:#059669;--tvam:#b45309;--vcb:#6d28d9;--fs:#7c3aed;--pos:#15803d;--neg:#dc2626;--warn:#b45309;--mono:'IBM Plex Mono',monospace;--sans:'IBM Plex Sans',sans-serif}
html,body{font-family:var(--sans);background:var(--bg);color:var(--text);height:100%;overflow:hidden}
body{display:flex;flex-direction:column}
.hdr{padding:6px 14px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0}
.hdr-title{font-size:13px;font-weight:700}.hdr-title span{color:var(--tvam)}
.badge{font-family:var(--mono);font-size:9px;padding:2px 6px;border-radius:2px;background:var(--surface2);border:1px solid var(--border2);color:var(--muted)}.badge.run{border-color:var(--tvam);color:var(--tvam);font-weight:600}
.hi{font-family:var(--mono);font-size:10px;color:var(--muted)}.hi b{color:var(--text);font-weight:500}
.hdr-r{margin-left:auto;display:flex;gap:5px}
.hb{padding:3px 10px;border:1px solid var(--border2);background:var(--surface);font-size:10px;font-weight:500;cursor:pointer;border-radius:3px}.hb:hover{border-color:var(--text)}
.logbar{padding:3px 14px;background:#fffef9;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:10px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:0}.logbar b{font-weight:600}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
/* Resizer */
.resizer{height:6px;background:var(--border);cursor:ns-resize;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:background .15s}.resizer:hover,.resizer.active{background:var(--tvam)}.resizer::after{content:'';width:30px;height:2px;border-radius:1px;background:rgba(255,255,255,.7)}
/* SIM */
.sim{display:grid;grid-template-columns:1.1fr 1fr 1.6fr 1.2fr;min-height:150px;border-bottom:none;overflow:hidden;flex-shrink:0}
.pnl{border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}.pnl:last-child{border-right:none}
.ph{padding:4px 8px;border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0;display:flex;align-items:center;gap:6px}
.ph h2{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em}
.ph.u h2{color:var(--user)}.ph.m h2{color:var(--momo)}.ph.t h2{color:var(--tvam)}.ph.v h2{color:var(--vcb)}
.pb{padding:5px 7px;overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:4px;font-size:12px}
.pb::-webkit-scrollbar{width:2px}.pb::-webkit-scrollbar-thumb{background:var(--border2)}
/* Tabs */
.tabs{display:flex;gap:0;flex-shrink:0}.tab{flex:1;padding:4px 5px;font-size:10px;font-weight:600;text-align:center;cursor:pointer;border-bottom:2px solid transparent;color:var(--muted);background:var(--surface2);text-transform:uppercase;letter-spacing:.04em}.tab.on{color:var(--tvam);border-bottom-color:var(--tvam);background:var(--surface)}.tab:hover{color:var(--tvam)}
.tpane{display:none;flex:1;overflow-y:auto;padding:5px 7px}.tpane.on{display:flex;flex-direction:column;gap:4px}
/* Components */
.ut{display:flex;gap:3px}.utb{flex:1;padding:4px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--muted);border-radius:3px;text-align:center}.utb.on{background:rgba(37,99,235,.1);border-color:var(--user);color:var(--user)}.utn{font-size:9px;margin-top:1px;opacity:.7}
.nb{padding:6px;background:rgba(37,99,235,.04);border:1px solid rgba(37,99,235,.2);border-radius:3px;text-align:center}.nv{font-size:18px;font-family:var(--mono);font-weight:600}.ns{font-size:10px;color:var(--muted);margin-top:1px;font-family:var(--mono)}
.ab{background:var(--surface);border:1px solid var(--border);border-radius:3px;padding:5px 7px}.al{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:2px;display:flex;align-items:center;gap:3px}.al::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor}.al.u{color:var(--user)}.al.m{color:var(--momo)}.al.t{color:var(--tvam)}.al.v{color:var(--vcb)}
.ar{display:flex;justify-content:space-between;padding:2px 0;border-bottom:1px solid var(--border);font-size:11px}.ar:last-child{border-bottom:none}.ak{color:var(--muted);font-family:var(--mono);font-size:10px}.av{font-family:var(--mono);font-weight:500;font-size:11px}
.ig{background:var(--surface);border:1px solid var(--border);border-radius:3px;padding:5px 7px}.ig label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);display:block;margin-bottom:2px}
.ir{display:flex;gap:3px;align-items:center}.ir input{flex:1;padding:3px 5px;border:1.5px solid var(--border2);font-family:var(--mono);font-size:11px;border-radius:2px;outline:none;background:var(--surface)}.ir input:focus{border-color:var(--user)}
.ib{padding:3px 8px;border:1px solid;border-radius:2px;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap}.ib.nap{border-color:var(--user);color:var(--user);background:rgba(37,99,235,.07)}.ib.nap:hover{background:var(--user);color:#fff}.ib.rut{border-color:var(--neg);color:var(--neg);background:rgba(220,38,38,.07)}.ib.rut:hover{background:var(--neg);color:#fff}
.jb{width:100%;padding:5px 7px;border:1.5px solid var(--border2);background:var(--surface);border-radius:3px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;text-align:left;margin-top:2px;font-size:11px}.jb:disabled{opacity:.3;cursor:not-allowed}.jb:not(:disabled):hover{border-color:var(--tvam);background:rgba(180,83,9,.06)}.jb.done{border-color:var(--pos);background:rgba(21,128,61,.05)}.jb.rdy{border-color:var(--tvam);background:rgba(180,83,9,.07);font-weight:600}
.jn{font-size:11px;font-weight:600}.js{font-size:9px;color:var(--muted)}.jt{font-family:var(--mono);font-size:9px;padding:2px 5px;border-radius:2px;border:1px solid}.jt.idle{background:var(--surface2);color:var(--muted);border-color:var(--border2)}.jt.rdy{background:#fef3c7;color:var(--warn);border-color:#fcd34d}.jt.done{background:#dcfce7;color:var(--pos);border-color:#86efac}
.ub{padding:3px 5px;background:var(--surface2);border-radius:2px;margin-bottom:2px;font-size:10px}.ul{font-weight:700;font-size:9px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:1px}.ul.a{color:var(--user)}.ul.b{color:#d97706}.ul.c{color:var(--momo)}.ur{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px}
@keyframes flashIn{0%{background:rgba(217,119,6,.4)}100%{background:rgba(217,119,6,.15)}}.chg{animation:flashIn .4s ease-out forwards;background:rgba(217,119,6,.15);border-radius:2px;padding:0 2px;margin:-0px -2px}
/* CD import */
.cd-inp{width:70px;padding:3px 5px;border:1px solid var(--border2);font-family:var(--mono);font-size:11px;border-radius:2px;text-align:right;outline:none;background:var(--surface)}.cd-inp:focus{border-color:var(--tvam)}
.lo-card{padding:5px 7px;background:var(--surface);border:1px solid var(--border);border-radius:3px;margin-bottom:3px;font-size:10px;font-family:var(--mono)}
.lo-card .lo-h{font-weight:700;font-size:11px;color:var(--tvam);margin-bottom:2px}
/* LSGD table */
.lsgd{width:100%;border-collapse:collapse;font-size:10px;font-family:var(--mono)}.lsgd th{padding:3px 5px;background:var(--surface2);text-align:left;font-size:9px;text-transform:uppercase;border-bottom:1px solid var(--border)}.lsgd td{padding:3px 5px;border-bottom:1px solid var(--border)}
/* Lãi log */
.lai-row{display:flex;justify-content:space-between;font-family:var(--mono);font-size:11px;padding:2px 0;border-bottom:1px solid var(--border)}
/* ═══ FLOW ═══ */
.flow{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--surface)}
.fh{padding:4px 14px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0}
.fh h3{font-size:10px;font-weight:700;color:var(--tvam);text-transform:uppercase;letter-spacing:.06em}
.fc{display:flex;gap:4px;margin-left:auto;align-items:center}
.fc button{padding:2px 8px;border:1px solid var(--border2);background:var(--surface);font-size:9px;font-weight:500;cursor:pointer;border-radius:3px}.fc button:hover{border-color:var(--tvam);color:var(--tvam)}.fc button.act{background:var(--tvam);color:#fff;border-color:var(--tvam)}.fc button:disabled{opacity:.3;cursor:not-allowed}
.fsi{font-family:var(--mono);font-size:9px;color:var(--muted);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.fsi b{color:var(--text);font-weight:600}
.seq-wrap{flex:1;overflow-x:hidden;overflow-y:auto}.seq-wrap::-webkit-scrollbar{width:3px}.seq-wrap::-webkit-scrollbar-thumb{background:var(--border2)}
.sys-head{display:flex;position:sticky;top:0;z-index:10}.sys-band{display:flex;flex-direction:column;border-right:2px solid var(--border2)}.sys-band:last-child{border-right:none}.sys-title{text-align:center;padding:3px 0;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#fff}.sys-title.bg-m{background:var(--momo)}.sys-title.bg-t{background:var(--tvam)}.sys-title.bg-v{background:var(--vcb)}
.sys-cols{display:flex}.sys-col{flex:1;text-align:center;padding:3px 2px;font-size:7px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);border-right:1px solid var(--border);background:var(--surface2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.sys-col:last-child{border-right:none}
.seq-body{position:relative;padding-bottom:40px;min-height:60px}
.col-line{position:absolute;top:0;bottom:0;border-left:1px dashed rgba(0,0,0,.08);z-index:0;pointer-events:none}
.sys-bdr{position:absolute;top:0;bottom:0;border-left:2px solid var(--border2);z-index:1;pointer-events:none}
.seq-row{position:relative;height:38px;z-index:2;opacity:0;transition:opacity .2s}.seq-row.vis{opacity:1}
.seq-arrow{position:absolute;height:2.5px;z-index:3;border-radius:1px}
.arr-hd{position:absolute;top:50%;transform:translateY(-50%);width:0;height:0;border-style:solid}.arr-hd.r{right:-1px;border-width:5px 0 5px 8px;border-color:transparent transparent transparent currentColor}.arr-hd.l{left:-1px;border-width:5px 8px 5px 0;border-color:transparent currentColor transparent transparent}
.seq-lbl{position:absolute;font-family:var(--mono);font-size:8px;font-weight:500;white-space:nowrap;z-index:4;padding:0 3px;border-radius:2px;background:rgba(255,255,255,.92);bottom:100%;margin-bottom:2px;pointer-events:none}
@keyframes pulse{0%{transform:translateX(-50%) scale(1)}50%{transform:translateX(-50%) scale(1.8)}100%{transform:translateX(-50%) scale(1)}}
@keyframes actPulse{0%{opacity:.3;transform:scaleY(.5)}50%{opacity:1;transform:scaleY(1.1)}100%{opacity:1;transform:scaleY(1)}}
.seq-ball{position:absolute;width:12px;height:12px;border-radius:50%;z-index:6;opacity:0;pointer-events:none;filter:drop-shadow(0 0 6px currentColor);transform:translateX(-50%)}
.seq-ball.ready{opacity:1;transition:none}.seq-ball.moving{opacity:1;transition:left .6s cubic-bezier(.25,.1,.25,1)}.seq-ball.arrived{opacity:1;animation:pulse .3s ease-out}
.seq-phase{position:relative;height:22px;display:flex;align-items:center;padding:0 10px;z-index:2;background:rgba(180,83,9,.06);border-top:1px solid rgba(180,83,9,.2);border-bottom:1px solid rgba(180,83,9,.2)}
.seq-phase-lbl{font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--tvam)}
.ubadge{position:absolute;top:2px;font-size:7px;font-weight:700;padding:0 4px;border-radius:2px;z-index:5;font-family:var(--mono);letter-spacing:.03em;left:4px}
</style>
</head>
<body>
<div class="hdr"><div class="hdr-title">TTT-New <span>Flow</span></div><div class="badge" id="pb">IDLE</div><div class="badge">Phiên <b id="bi" style="color:var(--tvam)">0001</b></div><div class="hi">Giá: <b id="pd">–</b></div><div class="hi">Ngày: <b id="dd">T0</b></div><div class="hdr-r"><button class="hb" onclick="copyActions()">📋 Actions</button><button class="hb" onclick="showReplay()">▶ Replay</button><button class="hb" onclick="copyLog()" id="bcl">📋 Log</button><button class="hb" onclick="resetAll()">Reset</button></div></div>
<div class="logbar" id="lb">Sẵn sàng.</div>
<div class="main">
<div class="sim">
<!-- USER panel with tabs -->
<div class="pnl"><div class="ph u"><h2>User</h2></div>
<div class="tabs"><div class="tab on" onclick="uTab(0)">Giao dịch</div><div class="tab" onclick="uTab(1)">Lịch sử lãi</div></div>
<div class="tpane on" id="utp0">
  <div class="ut"><button class="utb on" id="ut0" onclick="selU(0)">A<div class="utn" id="un0">–</div></button><button class="utb" id="ut1" onclick="selU(1)">B<div class="utn" id="un1">–</div></button><button class="utb" id="ut2" onclick="selU(2)">C<div class="utn" id="un2">–</div></button></div>
  <div class="nb"><div style="font-size:7px;color:var(--user);text-transform:uppercase;letter-spacing:.06em" id="ulb">User A · Ngăn 31</div><div class="nv" id="un31">0đ</div><div class="ns" id="uns">–</div></div>
  <div class="ab"><div class="al u">Ví MoMo</div><div class="ar"><span class="ak">Số dư</span><span class="av" id="uvi">100.000.000đ</span></div></div>
  <div class="ig"><label>Nạp tiền</label><div class="ir"><input id="inap" value="500000"/><button class="ib nap" onclick="doNap()">Nạp</button></div></div>
  <div class="ig"><label>Rút tiền</label><div class="ir"><input id="irut" value="200000"/><button class="ib rut" onclick="doRut()">Rút</button></div><div style="margin-top:2px;display:flex;gap:4px;align-items:center"><button onclick="fillMax()" style="font-size:8px;padding:1px 5px;border:1px solid var(--neg);border-radius:2px;background:rgba(239,68,68,.06);color:var(--neg);cursor:pointer;font-weight:600">Rút hết</button><span style="font-size:8px;color:var(--muted);font-family:var(--mono)">N31:<span id="umx">0đ</span></span></div></div>
  <button class="ib" style="width:100%;border-color:var(--tvam);color:var(--tvam);background:rgba(180,83,9,.06);padding:3px" onclick="advDay()">Bấm để qua ngày và tính lãi</button>
  <div id="advHint" style="display:none;font-size:8px;color:var(--tvam);margin-top:2px;padding:3px 6px;background:rgba(180,83,9,.06);border-radius:2px;font-family:var(--mono)">Bạn cần bấm thêm 1 lần nữa vì tính lãi vào T2</div>
</div>
<div class="tpane" id="utp1" style="font-size:9px">
  <div style="font-size:8px;font-weight:600;color:var(--tvam);margin-bottom:4px">Lịch sử lãi (per user)</div>
  <div id="laiLog">Chưa có lãi</div>
</div>
</div>

<!-- MOMO panel -->
<div class="pnl"><div class="ph m"><h2>MoMo</h2></div><div class="pb">
  <div class="ab"><div class="al m">Thu hộ TVAM</div><div class="ar"><span class="ak">Số dư</span><span class="av" id="mth">0đ</span></div></div>
  <div class="ab"><div class="al m">Finsight Pool</div><div class="ar"><span class="ak">Target</span><span class="av" id="mpx">5.000.000đ</span></div><div class="ar"><span class="ak">Hiện tại</span><span class="av" id="mpl">5.000.000đ</span></div><div class="ar"><span class="ak">Đã ứng</span><span class="av" id="mug">0đ</span></div></div>
  <div class="ab"><div class="al m">Thu hộ VCB</div><div class="ar"><span class="ak">Số dư</span><span class="av" id="mtv">0đ</span></div></div>
  <div class="ab"><div class="al m">Tổng phiên</div><div class="ar"><span class="ak">∑ nạp</span><span class="av" id="msn">+0đ</span></div><div class="ar"><span class="ak">∑ rút</span><span class="av" id="msr">-0đ</span></div></div>
</div></div>

<!-- TVAM panel with tabs: Jobs | CD Kho | LSGD -->
<div class="pnl"><div class="ph t"><h2>TVAM</h2></div>
<div class="tabs"><div class="tab on" onclick="tTab(0)">Jobs</div><div class="tab" onclick="tTab(1)">CD Kho</div><div class="tab" onclick="tTab(2)">LSGD</div><div class="tab" onclick="tTab(3)">Bảng giá</div></div>
<div class="tpane on" id="ttp0">
  <div class="ab"><div class="al t">Per-user</div><div id="tug"></div></div>
  <div style="font-size:7px;color:var(--dim);text-transform:uppercase;display:flex;align-items:center;gap:5px">Jobs<span style="flex:1;height:1px;background:var(--border)"></span></div>
  <button class="jb" id="bjr" onclick="jRut()" disabled><div><div class="jn">Job Rút</div><div class="js">sell_CD → withdraw</div></div><span class="jt idle" id="sr">idle</span></button>
  <button class="jb" id="bjm" onclick="jMoMo()" disabled><div><div class="jn">Job MoMo</div><div class="js">Refill → dep_Tổng</div></div><span class="jt idle" id="sm">idle</span></button>
  <button class="jb" id="bjn" onclick="jNap()" disabled><div><div class="jn">Job Nạp</div><div class="js">dep_User → buy_CD</div></div><span class="jt idle" id="sn">idle</span></button>
  <button class="jb" id="bjc" onclick="closeSes()" disabled><div><div class="jn">Đóng phiên</div></div><span class="jt idle" id="sc">idle</span></button>
  <button class="jb" id="brl" onclick="rollback()" disabled style="border-color:var(--neg);color:var(--neg);margin-top:4px"><div><div class="jn">↩ Rollback</div><div class="js" id="rlbl">Hoàn tác job vừa chạy</div></div><span class="jt" style="color:var(--neg)">–</span></button>
</div>
<div class="tpane" id="ttp1">
  <div style="font-size:8px;font-weight:600;color:var(--tvam);margin-bottom:4px">Kho CD hiện tại & Thứ tự mua</div>
  <div id="cdLoList"></div>
  <div style="margin-top:4px;font-size:8px;color:var(--muted)" id="loPriDisp">Auto (qty giảm dần)</div>
  <button class="ib" style="width:100%;border-color:var(--muted);color:var(--muted);padding:2px;margin-top:2px;font-size:8px" onclick="resetPri()">Reset thứ tự</button>
  <div style="margin-top:8px;font-size:8px;font-weight:600;color:var(--tvam);margin-bottom:4px">Nhập lô CD mới</div>
  <div class="ab" style="padding:6px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3px">
      <div><div style="font-size:7px;color:var(--muted);font-weight:600;margin-bottom:1px">Mệnh giá</div><input class="cd-inp" id="ci-f" value="100000" style="width:100%"/></div>
      <div><div style="font-size:7px;color:var(--muted);font-weight:600;margin-bottom:1px">LS (%/năm)</div><input class="cd-inp" id="ci-r" value="7" style="width:100%"/></div>
      <div><div style="font-size:7px;color:var(--muted);font-weight:600;margin-bottom:1px">Kỳ hạn (ngày)</div><input class="cd-inp" id="ci-t" value="365" style="width:100%"/></div>
      <div><div style="font-size:7px;color:var(--muted);font-weight:600;margin-bottom:1px">Số lượng</div><input class="cd-inp" id="ci-q" value="5000" style="width:100%"/></div>
    </div>
    <button class="ib" style="width:100%;border-color:var(--vcb);color:var(--vcb);background:rgba(109,40,217,.07);padding:3px;margin-top:4px" onclick="importCD()">Nhập kho CD</button>
  </div>
</div>
<div class="tpane" id="ttp2">
  <div style="font-size:8px;font-weight:600;color:var(--tvam);margin-bottom:4px">Lịch sử giao dịch</div>
  <div style="overflow-x:auto"><table class="lsgd"><thead><tr><th>Phiên</th><th>User</th><th>Loại</th><th>Lô</th><th>SL CD</th><th>Giá</th><th>Tiền</th></tr></thead><tbody id="lsgdB"><tr><td colspan="7" style="color:var(--muted)">Chưa có</td></tr></tbody></table></div>
</div>
<div class="tpane" id="ttp3">
  <div style="font-size:8px;font-weight:600;color:var(--tvam);margin-bottom:4px">Bảng giá CD theo ngày</div>
  <div style="display:flex;gap:3px;margin-bottom:4px;flex-wrap:wrap" id="ptLoSel"></div>
  <div style="overflow-y:auto;max-height:100%"><table class="lsgd"><thead><tr><th>Ngày</th><th>Giá CD</th><th>Lãi/ngày</th><th>Giá trị lô</th></tr></thead><tbody id="ptBody"><tr><td colspan="4" style="color:var(--muted)">Chọn lô</td></tr></tbody></table></div>
</div>
</div>

<!-- VCB panel with tabs -->
<div class="pnl"><div class="ph v"><h2>VCB</h2></div>
